{
  "name": "sci-log-db",
  "version": "2.1.6",
  "description": "SciLogDB",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=10.16"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "npm run prettier:check && npm run eslint",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- --check",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run clean && npm run build",
    "test": "lb-mocha --allow-console-logs --exit \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "docker:build": "docker build -t sci-log-db .",
    "docker:run": "docker run -p 3000:3000 -d sci-log-db",
    "migrate": "node ./dist/migrate",
    "openapi-spec": "node ./dist/openapi-spec",
    "prestart": "npm run build",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "start": "node -r source-map-support/register .",
    "stop": "pm2 stop ecosystem.config.js --env production",
    "logs": "pm2 logs",
    "delete-pm2": "pm2 delete 0",
    "start-local": "npm run build && node .",
    "start:watch": "tsc-watch --target es2017 --outDir ./dist --onSuccess \"node .\""
  },
  "repository": {
    "type": "git"
  },
  "author": "",
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/authentication": "12.0.12",
    "@loopback/authentication-jwt": "0.16.12",
    "@loopback/authentication-passport": "8.0.12",
    "@loopback/authorization": "0.16.11",
    "@loopback/boot": "8.0.11",
    "@loopback/core": "7.0.10",
    "@loopback/repository": "8.0.10",
    "@loopback/rest": "15.0.11",
    "@loopback/rest-explorer": "8.0.11",
    "@loopback/service-proxy": "8.0.10",
    "archiver": "7.0.1",
    "connect-mongo": "4.6.0",
    "express-session": "1.19.0",
    "formidable": "2.1.3",
    "isemail": "3.2.0",
    "jsdom": "16.7.0",
    "ldapjs-promise": "1.0.7",
    "loopback-connector-mongodb": "5.6.0",
    "multer": "2.1.1",
    "passport-openidconnect": "0.1.2",
    "pdf-merger-js": "4.3.1",
    "pm2": "4.5.6",
    "prismjs": "1.30.0",
    "puppeteer": "19.11.1",
    "ro-crate": "3.6.1",
    "ro-crate-html": "0.1.6",
    "tar": "7.5.11",
    "tslib": "2.0.0"
  },
  "devDependencies": {
    "@loopback/build": "12.0.10",
    "@loopback/eslint-config": "16.0.1",
    "@loopback/testlab": "8.0.10",
    "@types/archiver": "6.0.4",
    "@types/express-session": "1.18.2",
    "@types/formidable": "2.0.6",
    "@types/jsdom": "21.1.7",
    "@types/ldapjs": "1.0.11",
    "@types/multer": "2.1.0",
    "@types/node": "16.18.126",
    "@types/passport": "1.0.17",
    "@types/prismjs": "1.26.6",
    "eslint": "8.57.1",
    "source-map-support": "0.5.21",
    "tsc-watch": "5.0.3",
    "typescript": "5.2.2",
    "yauzl": "3.2.1"
  }
}
